{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dev: Start server",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/apps/saas" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "new" },
      "problemMatcher": "$tsc"
    },
    {
      "label": "Check: TypeScript",
      "type": "shell",
      "command": "npm run typecheck",
      "options": { "cwd": "${workspaceFolder}/apps/saas" },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": "$tsc"
    },
    {
      "label": "Check: Tests",
      "type": "shell",
      "command": "npm run test",
      "options": { "cwd": "${workspaceFolder}/apps/saas" },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Check: Lint",
      "type": "shell",
      "command": "npm run lint",
      "options": { "cwd": "${workspaceFolder}/apps/saas" },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Build: Production",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/apps/saas" },
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": "$tsc"
    },
    {
      "label": "DB: Push migrations",
      "type": "shell",
      "command": "bash scripts/db-push.sh",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Plugin: Package zip",
      "type": "shell",
      "command": "bash scripts/package-plugin.sh",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" }
    }
  ]
}
