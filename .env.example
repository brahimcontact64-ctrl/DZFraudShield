# =============================================================================
# Zaki — SaaS Platform · Environment Variables Reference
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env, .env.local, or any file with real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Security & Signing
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
API_KEY_SIGNING_SECRET=replace-with-64-char-hex-secret

# Generate with: openssl rand -hex 32
PHONE_HASH_SECRET=replace-with-64-char-hex-secret

# AES-256 key for delivery account credential encryption. Must be 64 hex chars.
# Generate with: openssl rand -hex 32
DELIVERY_ACCOUNT_ENCRYPTION_KEY=replace-with-64-char-hex-secret

# Secret for authenticating Vercel cron invocations.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-64-char-hex-secret

# Optional alias — falls back to CRON_SECRET if not set.
DELIVERY_SYNC_CRON_SECRET=replace-with-64-char-hex-secret

# Shared secret for verifying incoming delivery provider webhooks.
DELIVERY_WEBHOOK_SECRET=replace-with-strong-random-secret

# Shared secret for background job processing endpoint.
BACKGROUND_JOBS_SECRET=replace-with-strong-random-secret

# -----------------------------------------------------------------------------
# Web Push / VAPID
# -----------------------------------------------------------------------------
# Generate a VAPID key pair with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Optional: expose public key to browser directly (alternative to /api/v1/pwa/push/config)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------
# HTTP Basic Auth for /admin/* routes.
ADMIN_NETWORK_USER=admin
ADMIN_NETWORK_PASSWORD=replace-with-strong-password

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
